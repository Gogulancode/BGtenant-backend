# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/accountability?schema=public"

# JWT
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3002
NODE_ENV="production"
FRONTEND_ORIGINS="https://your-tenant-web-domain.vercel.app,http://localhost:8080,http://localhost:5173"

# Ops Service Auth
OPS_SERVICE_TOKEN="replace-with-secure-token"

# Redis Cache
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Email / Invitations
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
INVITE_TOKEN_TTL_HOURS=72
INVITE_ACCEPT_BASE_URL="https://your-tenant-web-domain.vercel.app/accept-invite"

# MFA
MFA_ISSUER="BGAccountability"
